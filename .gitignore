# ==============================================================================
# Serena Backend — .gitignore
# ==============================================================================

# --- Environment variables (NEVER commit secrets) ---
.env
.env.local
.env.production

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Testing & Coverage ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# --- Alembic (keep versions tracked, ignore pycache inside) ---
alembic/versions/__pycache__/

# --- IDEs ---
.idea/
.vscode/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Docker volumes ---
postgres_data/
redis_data/
