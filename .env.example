# ==============================================================================
# Serena Backend — Environment Variables Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ==============================================================================

# --- Application ---
APP_NAME="Serena API"
APP_VERSION="1.0.0"
DEBUG=true

# --- Database ---
# When running inside Docker on Linux, use host.docker.internal to reach
# the PostgreSQL instance on the host machine.
DATABASE_URL=postgresql+asyncpg://postgres:123@db:5432/serena_db
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:123@db:5432/serena_db

# When running locally (without Docker), change host.docker.internal → localhost:
# DATABASE_URL=postgresql+asyncpg://postgres:123@localhost:5432/serena_db
# SYNC_DATABASE_URL=postgresql+psycopg2://postgres:123@localhost:5432/serena_db

# --- Security ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis (Celery broker & result backend) ---
# Points to the Redis container defined in docker-compose.yml
REDIS_URL=redis://redis:6379/0

# --- Cloudinary (media storage) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- CORS ---
# JSON array of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
